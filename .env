# ==============================================
# .env — Конфигурация GraphRAG (Узбекистан)
# ==============================================

# --- LLM (Генерация ответов) ---
# Для OpenAI: https://api.openai.com/v1
# Для Ollama (локально): http://host.docker.internal:11434/v1
OPENAI_API_BASE=https://openrouter.ai/api/v1/chat/completions
OPENAI_API_KEY=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
LLM_MODEL=openrouter/free

# --- Embeddings (Векторизация) ---
# Важно: модель должна поддерживать узбекский язык
# Опции: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (локально)
#         или openai/text-embedding-3-small (через API)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# --- Neo4j (База данных) ---
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=LegalGraph2024!
NEO4J_DATABASE=neo4j

# --- Настройки обработки ---
CHUNK_SIZE=2048
LANGUAGE=uz
KNN_MIN_SCORE=0.95

# --- Сервер (FastAPI) ---
HOST=0.0.0.0
PORT=8000
ENV=PROD

# --- Лимиты ---
MAX_CONTEXT_CHUNKS=5
MAX_TOKENS=1024
