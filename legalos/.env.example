# --- Infrastructure ---
POSTGRES_USER=legalos
POSTGRES_PASSWORD=legalos
POSTGRES_DB=legalos
MINIO_ROOT_USER=legalos
MINIO_ROOT_PASSWORD=legalos-secret
RABBITMQ_USER=legalos
RABBITMQ_PASSWORD=legalos

# --- Application ---
LEGALOS_ENVIRONMENT=development
LEGALOS_SECRET_KEY=generate-a-long-random-string

# --- AI providers (fill in at least the default one) ---
LEGALOS_DEFAULT_AI_PROVIDER=openai
LEGALOS_DEFAULT_AI_MODEL=gpt-4o-mini
LEGALOS_OPENAI_API_KEY=
LEGALOS_DEEPSEEK_API_KEY=
LEGALOS_GEMINI_API_KEY=
LEGALOS_QWEN_API_KEY=
# Any OpenAI-compatible endpoint (Gemma via Ollama/vLLM, on-prem model):
LEGALOS_COMPATIBLE_BASE_URL=
LEGALOS_COMPATIBLE_API_KEY=
LEGALOS_COMPATIBLE_MODEL=

# --- Embeddings ---
LEGALOS_EMBEDDING_PROVIDER=openai
LEGALOS_EMBEDDING_MODEL=text-embedding-3-small
LEGALOS_EMBEDDING_DIM=1536

# --- Telegram (HR Assistant Free) ---
LEGALOS_TELEGRAM_BOT_TOKEN=

# --- SSO / OIDC (Enterprise; leave empty to disable) ---
LEGALOS_OIDC_DISCOVERY_URL=
LEGALOS_OIDC_CLIENT_ID=
LEGALOS_OIDC_CLIENT_SECRET=
LEGALOS_OIDC_REDIRECT_URI=
LEGALOS_SSO_TENANT_SLUG=sso
LEGALOS_SSO_AUTO_PROVISION=true

# --- Knowledge Graph (optional Neo4j; leave empty to disable) ---
LEGALOS_NEO4J_URI=
LEGALOS_NEO4J_USERNAME=neo4j
LEGALOS_NEO4J_PASSWORD=

# --- RAG reranker: llm | cross_encoder | none ---
LEGALOS_RAG_RERANKER=llm
LEGALOS_CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# --- Legislative monitoring: hours between automatic checks of all tracked acts (0 = off) ---
LEGALOS_LEGISLATION_CHECK_INTERVAL_HOURS=24

# --- Security hardening ---
LEGALOS_AUTH_RATE_LIMIT_PER_MINUTE=30
LEGALOS_GUARD_LLM=false
